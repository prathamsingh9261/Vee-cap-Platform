# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (MongoDB Atlas connection string, or local mongodb://localhost:27017/veecap)
MONGO_URI=mongodb://localhost:27017/veecap

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Razorpay (get these from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
# Set this after creating a webhook in the Razorpay Dashboard (Settings > Webhooks)
RAZORPAY_WEBHOOK_SECRET=replace_me
